# LightChain Environment Configuration
# Copy this file to .env.local and customize for your environment

# Network Environment
NETWORK_ENV=development
NODE_ENV=development
RUST_LOG=info

# Blockchain Configuration
LIGHTCHAIN_NETWORK_ID=lightchain-devnet
LIGHTCHAIN_CHAIN_ID=2024
MINING_DIFFICULTY=4
BLOCK_TIME_SECONDS=10

# Network Settings
LISTEN_PORT=8080
RPC_PORT=8081
P2P_PORT=8082
REST_API_PORT=8083

# Database Settings
DATABASE_URL=sqlite:./data/lightchain.db
DATA_DIRECTORY=./data
BLOCKCHAIN_DB=blockchain.db
WALLET_DB=wallet.db

# API Configuration
ENABLE_RPC=true
ENABLE_REST_API=true
API_HOST=127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Security Settings
ENABLE_ENCRYPTION=true
JWT_SECRET=your_jwt_secret_here_change_in_production
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# Sideline_Pinas Integration
MARKETPLACE_API_URL=https://api.sideline-pinas.com
MARKETPLACE_API_KEY=your_api_key_here
WEBHOOK_URL=https://lightchain.eco/webhook
WEBHOOK_SECRET=your_webhook_secret_here
INTEGRATION_TOKEN=your_integration_token_here
SYNC_INTERVAL=30

# Environmental Governance
CARBON_CREDIT_RATE=0.1
SUSTAINABILITY_SCORE_THRESHOLD=7.0
ENVIRONMENTAL_DATA_REWARD=1.0
VERIFICATION_REWARD=5.0

# Governance Settings
PROPOSAL_VOTING_PERIOD=604800
MINIMUM_VOTING_POWER=100.0
QUORUM_THRESHOLD=0.5
APPROVAL_THRESHOLD=0.6

# Mining Configuration
MINING_REWARD=10.0
TRANSACTION_FEE=0.01
MAX_TRANSACTIONS_PER_BLOCK=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/lightchain.log
ENABLE_FILE_LOGGING=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_PORT=9091

# Development Settings (remove in production)
ENABLE_DEV_TOOLS=true
ENABLE_MOCK_DATA=false
SKIP_GENESIS_VALIDATION=false
